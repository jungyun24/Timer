{
  "manifest_version": 3,
  "name": "출근→퇴근 달리기",
  "version": "1.1.0",
  "description": "현재 탭의 주소창(해시)과 탭 제목에서 캐릭터가 출근→퇴근으로 달려갑니다.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "출근→퇴근 달리기 설정",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "run-to-home@jy.local",
      "strict_min_version": "109.0"
    }
  }
}
